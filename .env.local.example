# Copy to .env.local for local dev (optional locally — sensible defaults apply).
# REQUIRED on Vercel.

# Admin secret protecting all write actions (upload, set-active, run/reset).
ADMIN_SECRET=etoile-bleue-admin

# Natural voice generation (ElevenLabs). Required to generate voices from /admin.
# Get a key at https://elevenlabs.io (free tier available).
ELEVENLABS_API_KEY=

# --- Vercel KV (Upstash Redis) — injected automatically by the Vercel KV integration ---
# KV_REST_API_URL=...
# KV_REST_API_TOKEN=...

# --- Vercel Blob — injected automatically by the Vercel Blob integration ---
# BLOB_READ_WRITE_TOKEN=...
